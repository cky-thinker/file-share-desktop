{
  "name": "file-share-desktop",
  "version": "1.0.0",
  "description": "文件共享",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env NODE_ENV='dev' && electron .",
    "pack": "electron-builder --dir"
  },
  "build": {
    "productName": "文件共享工具",
    "appId": "tk.ckyspace.fileShare",
    "win": {
      "icon": "public/favicon.ico",
      "artifactName": "${productName}-${platform}-${arch}-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "copyright": "Copyright © year ${author}"
  },
  "author": "宇的季节",
  "license": "ISC",
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^27.1.0",
    "electron-builder": "^24.13.3"
  }
}
